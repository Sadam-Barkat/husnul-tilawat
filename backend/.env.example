# MongoDB (required). If mongodb+srv fails with queryTxt ETIMEOUT, add the standard URI from Atlas:
# MONGO_URI_DIRECT=mongodb://USER:PASS@host1:27017,host2:27017,host3:27017/DATABASE?ssl=true&replicaSet=...&authSource=admin
# If SRV works but TXT is flaky, you can set replica set name from Atlas Connect screen:
# ATLAS_REPLICA_SET=atlas-xxxxx-shard-0
# MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1
# MONGO_URI=mongodb+srv://...
# Optional: force database name (otherwise URI path is used, or "husnultilawat" if URI has no DB / uses "test")
# MONGO_DB_NAME=husnultilawat

# --- Email (Gmail): 2FA on, create App Password; SMTP_PASSWORD may include spaces (stripped for Gmail).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_EMAIL=youraddress@gmail.com
# SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# Optional: SMTP_DEBUG=1  (verbose SMTP logs)
# Optional: SMTP_SKIP_VERIFY=1  (skip verify(); not recommended)

# Local Python AI backend (ASR)
PYTHON_AI_URL=http://localhost:8001

# ElevenLabs TTS (Lessons Listen)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
